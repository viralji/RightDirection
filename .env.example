# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/rightdirection

# ─── REDIS ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── AI PROVIDERS ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=rightdirection-documents
AWS_CLOUDFRONT_URL=https://cdn.rightdirection.com

# ─── EMAIL ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@rightdirection.com

# ─── SMS / WHATSAPP ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
GUPSHUP_API_KEY=
GUPSHUP_APP_NAME=

# ─── PAYMENTS ────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── INTERNAL SERVICES ───────────────────────────────────────────────────────
INTERNAL_API_KEY=change_me_internal_api_key_min_32_chars
AI_SERVICE_URL=http://localhost:8000

# ─── APP ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4005
FRONTEND_URL=http://localhost:5175

# Web (optional — copy to web/.env.local)
# API_ORIGIN=http://localhost:4005
BASE_DOMAIN=rightdirection.com

# ─── PRODUCTION (do not commit) ─────────────────────────────────────────────
# Copy .env.production.example → .env.production for server deploy.
# Deploy: ./scripts/deploy-digitalocean.sh (scp .env.production → server)

# ─── MONITORING ──────────────────────────────────────────────────────────────
SENTRY_DSN=
